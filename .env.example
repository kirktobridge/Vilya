# Kalshi API
KALSHI_API_KEY=your_kalshi_api_key_here

# OpenWeather API (One Call 3.0)
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Database
DATABASE_URL=postgresql://bot:bot@localhost:5432/kalshi_bot

# Runtime
ENV=dev
LOG_LEVEL=INFO

# Target location (defaults to NYC Central Park)
TARGET_LOCATION=NYC_CENTRAL_PARK
TARGET_LAT=40.7828
TARGET_LON=-73.9654

# Trading controls
PAPER_TRADING=true
EV_THRESHOLD=0.03
MAX_CONTRACTS_PER_MARKET=5
MAX_DAILY_NOTIONAL=500
DRAWDOWN_KILL_SWITCH=100
POLL_INTERVAL_SECONDS=600
